# MeraCodeLikhDo — Backend Environment Variables
# Copy this to .env and fill in your values

# ── App ─────────────────────────────────────────────────────────────
DEBUG=true
USE_DEMO_DATA=true

# ── Database (PostgreSQL + PostGIS) ─────────────────────────────────
DATABASE_URL=postgresql://mcld:mcld2026@localhost:5432/mcld_db

# ── Google Earth Engine ─────────────────────────────────────────────
# Set USE_DEMO_DATA=false to use live GEE data
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
GEE_KEY_FILE=gee_key.json

# ── LLM / NLG (for multilingual advisory — USP 4.4) ─────────────────
# At least one of these is needed for LLM-enhanced advisory text
# Without API keys, the system uses built-in Hindi/English templates
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_LLM_PROVIDER=gemini

# ── Twilio (SMS/WhatsApp — USP 4.4) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+14155238886

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
